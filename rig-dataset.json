<script>

let rigs=[];

/* LOAD ORIGINAL V1 DATASET */

fetch("https://raw.githubusercontent.com/Wiggle2025/wiggle-rigs/main/rig-dataset.json")
.then(r=>r.json())
.then(data=>{
rigs=data;
console.log("Rig dataset loaded:",rigs.length);
});

/* FLOW CONTROL */

function showSpecies(){
document.getElementById("speciesBlock").style.display="block";
}

function showBait(){
document.getElementById("baitBlock").style.display="block";
}

function showAdvanced(){
document.getElementById("advancedBlock").style.display="block";
}

/* SAFE FIELD ACCESSOR (handles V1 variations) */

function getURL(rig){
return rig.u || rig.url || "#";
}

function getName(rig){
return rig.n || rig.name || "Unknown rig";
}

function getWhy(rig){
return rig.w || rig.why || "";
}

/* SCORING ENGINE */

function scoreRig(rig,user){

let score=0;

if(rig.l?.includes(user.environment)) score+=5;

if(rig.s===user.species || rig.s?.includes?.(user.species)){

score+=5;

if(getName(rig).toLowerCase().includes(user.species.toLowerCase()))
score+=3;
}

return score;
}

/* MAIN SELECTOR */

function findRig(){

if(rigs.length===0){

document.getElementById("resultPanel").innerHTML=
"Rig data still loading — try again in a moment.";

return;
}

const user={

environment:environment.value,
species:species.value

};

let ranked=rigs.map(r=>({
rig:r,
score:scoreRig(r,user)
}));

ranked.sort((a,b)=>b.score-a.score);

let best=ranked[0]?.rig;
let alt=ranked[1]?.rig;

document.getElementById("resultPanel").innerHTML=

"<h3>Recommended Rig</h3>"+

"<a href='"+getURL(best)+"' target='_blank' style='font-size:18px;font-weight:bold;'>"+
getName(best)+
"</a>"+

"<br><br><strong>Why this rig works</strong><br>"+
getWhy(best)+

(alt ? "<br><br><a href='"+getURL(alt)+"' target='_blank'>Alternative option: "+getName(alt)+"</a>" : "")+

"<br><br><a href='https://wiggleyawormrigs.com/rigs-explained' target='_blank'>Learn how this rig style works →</a>";

}

</script>
